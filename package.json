{
  "name": "posprint",
  "version": "0.1.0",
  "private": false,
  "description": "ESC/POS printing CLI for EPSON TM-T88V over Windows RAW spooler",
  "main": "src/print-cli.js",
  "bin": {
    "posprint": "src/print-cli.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "epson",
    "tm-t88v",
    "escpos",
    "receipt",
    "windows",
    "spooler",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chris/posprint.git"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "print": "node src/print-cli.js",
    "print:dry": "node src/print-cli.js --dry-run",
    "print:test": "node src/print-test.js",
    "print:test:dry": "node src/print-test.js --dry-run",
    "print:test:save": "node src/print-test.js --save",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
